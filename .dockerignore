# Keep the build context small and the image clean. Only Go sources and the
# embedded UI under internal/web/ui are needed to build.
.git
.gitignore
.claude
.dockerignore
Dockerfile
docker-compose.yml
# The workspace file ties the two modules together for local dev only; neither
# image build needs it (the local agent uses GOWORK=off, the cloud image builds
# its module standalone), and its go 1.25 directive would break the 1.20 build.
go.work
go.work.sum
*.md
data/
**/*.db
**/*.db-*
scratchpad/
